# Сборка PyInstaller
build/
dist/
*.spec
# SI-HYX.spec — не автогенерат, а вручную поддерживаемый единый источник
# правды для build.bat (datas/hiddenimports/excludes) — держим в git.
!SI-HYX.spec

# Python
__pycache__/
*.pyc

# Внешние бинарники (большие, кладутся в релиз-архив, не в репозиторий)
bin/
# Модель LaMa (~200 МБ) — тоже в релиз-архив, а не в git
models/

# Локальные/служебные файлы
settings.json
*.log
*_original_backup.py
# Случайный лог-маркер сборки build.bat (echo «Version: … -> …» в файл)
SI-HYX v*
YouTubecookies.txt
*cookies*.txt

graphify-out/
GRAPH_REPORT.md

# sigstats: локальный кэш/данные (см. sigstats/config.py, BASE_DIR)
/media/
/packages/
/sigstats.db
/author_blacklist.json
/package_blacklist.json
/package_blacklist_added_at.json
/played_packages.json
/played_packages_added_at.json
/search_page_cache.json
/ui_settings.json

# Временные файлы сторонних утилит (ab-av1 и т.п.)
.ab-av1-*/